# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Contact form (optional: sends email via Resend; if not set, form still works and falls back to mailto)
# RESEND_API_KEY=re_...
# RESEND_FROM=QM Fest <hola@qmfest.com>
# CONTACT_TO_EMAIL=hola@qmfest.com

# Analytics (optional; only loads if user accepts cookies)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=qmfest.com

# Stripe (create products/prices in Stripe Dashboard, then add Price IDs here)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_STRIPE_EARLY_BIRD_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_REGULAR_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_VIP_PRICE_ID=price_...
