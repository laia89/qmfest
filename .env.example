# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Contact email (UI, mailto links, and Resend: where form messages are sent from/to)
NEXT_PUBLIC_CONTACT_EMAIL=hello@queermusicfest.com

# Contact form (optional: sends email via Resend; if not set, form falls back to mailto)
# RESEND_API_KEY=re_...

# Playlist (optional; link to Spotify playlist; if not set, button goes to open.spotify.com)
# NEXT_PUBLIC_SPOTIFY_PLAYLIST_URL=https://open.spotify.com/playlist/...

# Analytics (optional; only loads if user accepts cookies)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=qmfest.com

# Stripe (create products/prices in Stripe Dashboard, then add Price IDs here)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_STRIPE_EARLY_BIRD_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_REGULAR_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_VIP_PRICE_ID=price_...
